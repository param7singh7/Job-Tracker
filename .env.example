# Core
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/job_radar?schema=public

# Scan scheduler
SCAN_CRON=0 */6 * * *
SCAN_MAX_PAGES=10
SCAN_TIMEOUT_MS=12000
PROVIDER_FETCH_TIMEOUT_MS=900000
ENABLE_MOCK_MODE=false
PROVIDER_BACKFILL_MIN_JOBS=0
MIN_POSTED_AT=2026-03-01
LINKEDIN_SCAN_STRATEGY=exhaustive
LINKEDIN_MAX_KEYWORDS=0
LINKEDIN_MAX_PAGES_PER_KEYWORD=18
LINKEDIN_STOP_AFTER_EMPTY_PAGES=2
LINKEDIN_MAX_TOTAL_REQUESTS=1400
LINKEDIN_REQUEST_DELAY_MS=550
LINKEDIN_KEYWORD_DELAY_MS=900
LINKEDIN_USE_BING_SUPPLEMENT=true
DAILY_TARGET_FETCHED=600
DAILY_TARGET_PARSED=300
DAILY_TARGET_LINKEDIN_VISIBLE=220
CSV_EXPORT_ENABLED=true
CSV_EXPORT_DIR=exports

# Provider mode: live | mock | off
PROVIDER_LINKEDIN_MODE=live
PROVIDER_JOBSIRELAND_MODE=off
PROVIDER_GLASSDOOR_MODE=live
PROVIDER_IRISHJOBS_MODE=off
PROVIDER_INDEED_MODE=live

# Optional provider feed URLs (when provider mode=live)
LINKEDIN_FEED_URL=
LINKEDIN_COOKIE=
JOBSIRELAND_FEED_URL=
GLASSDOOR_FEED_URL=
IRISHJOBS_FEED_URL=
INDEED_FEED_URL=

# Notifications
WEBHOOK_URLS=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
DIGEST_EMAIL_TO=
